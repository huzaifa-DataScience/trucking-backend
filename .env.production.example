# Production env template — set these on your server/CI; never commit real values.
# Copy to .env only for local testing against prod DB; keep .env in .gitignore.

PORT=3001
NODE_ENV=production

# SQL Server (GoFormz DB) — map from connection string:
#   Server=HOST;Database=DB;User Id=USER;Password=PASSWORD;TrustServerCertificate=true;
DB_HOST=ts01.8a.com
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=<set-on-server>
DB_DATABASE=GoFormzDB
DB_ENCRYPT=false
DB_TRUST_CERT=true
