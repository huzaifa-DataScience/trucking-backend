# =============================================================================
# Production environment — copy to server as `.env` and fill CHANGE_ME values.
# Commit-safe template (no real secrets). See docs/SITELINE_PM_EMAILS.md for email jobs.
# =============================================================================

PORT=3000
NODE_ENV=production

# --- Database ---
DB_HOST=CHANGE_ME
DB_PORT=1433
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_DATABASE=GoFormzDB
DB_ENCRYPT=true
DB_TRUST_CERT=false

# --- Auth ---
JWT_SECRET=CHANGE_ME_MIN_32_CHARS
JWT_EXPIRES_IN=7d

# --- Siteline external API (contracts / pay apps) ---
SITELINE_API_URL=https://api-external.siteline.com
SITELINE_API_TOKEN=CHANGE_ME
SITELINE_API_TOKEN_ENTITY_1=CHANGE_ME
SITELINE_API_TOKEN_ENTITY_2=CHANGE_ME
SITELINE_API_TOKEN_ENTITY_3=CHANGE_ME
SITELINE_AGING_COMPANY_ID_MODE=per_entity
SITELINE_AGING_PRIMARY_ENTITY_ID=2
SITELINE_ENTITY_API_DELAY_MS=2000
SITELINE_DISCOVERY_PAGE_DELAY_MS=300
SITELINE_GET_CONTRACT_DELAY_MS=300
SITELINE_DB_PERSIST_RETRIES=3
# Master kill-switch for ALL scheduled jobs. Keep true in production.
CRONS_ENABLED=true
SITELINE_AGING_SNAPSHOT_ENABLED=true
SITELINE_CONTRACT_SYNC_ENABLED=true
SITELINE_CONTRACT_SYNC_CRON=0 0 */6 * * *
SITELINE_AGING_SNAPSHOT_CRON=0 15 */6 * * *

# --- Siteline aging (api.siteline.com + Firebase login) ---
SITELINE_API_URL_SECONDARY=https://api.siteline.com
SITELINE_IDENTITY_API_KEY_SECONDARY=CHANGE_ME
SITELINE_AUTH_EMAIL_SECONDARY=CHANGE_ME
SITELINE_AUTH_PASSWORD_SECONDARY=CHANGE_ME

# --- Clearstory ---
CLEARSTORY_API_URL=https://web-api.clearstory.build
CLEARSTORY_KEY_ID=CHANGE_ME
CLEARSTORY_SECRET_KEY=CHANGE_ME
CLEARSTORY_SYNC_ENABLED=true
CLEARSTORY_SYNC_CRON=0 0 */6 * * *
CLEARSTORY_CUSTOMER_DETAIL=false

# --- Trimble (production: headless server) ---
TRIMBLE_EMAIL=CHANGE_ME
TRIMBLE_PASSWORD=CHANGE_ME
TRIMBLE_SYNC_ENABLED=true
TRIMBLE_SYNC_CRON=0 0 */6 * * *
TRIMBLE_RUN_ON_STARTUP=true
TRIMBLE_RUN_ON_STARTUP_DELAY_MS=5000
TRIMBLE_HEADLESS=true
TRIMBLE_SLOWMO_MS=0
TRIMBLE_LOGIN_TIMEOUT_MS=600000
TRIMBLE_SELECTOR_TIMEOUT_MS=90000
TRIMBLE_USER_DATA_DIR=/var/lib/trucking/.playwright-profile-trimble
TRIMBLE_DOWNLOAD_CONCURRENCY=3
TRIMBLE_DOWNLOAD_DELAY_MS=0

# --- Email (Gmail SMTP — no Resend until domain is verified) ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
OVERDUE_EMAIL_FROM=CHANGE_ME

# PM Monday 6:00 AM US Eastern — one email per PM (issues only + T&M)
PM_WEEKLY_REPORT_ENABLED=true
PM_WEEKLY_REPORT_CRON=0 0 6 * * 1
SITELINE_PM_EMAIL_TIMEZONE=America/New_York
PM_WEEKLY_REPORT_DAYS=50
# Leave empty in production (real PM inboxes)
PM_WEEKLY_REPORT_TEST_TO=

# PJ Tuesday 6:00 AM US Eastern — one email, PDF per PM
PJ_COR_WEEKLY_REPORT_ENABLED=true
PJ_COR_WEEKLY_REPORT_CRON=0 0 6 * * 2
PJ_COR_WEEKLY_REPORT_TO=CHANGE_ME_PJ_INBOX
PJ_COR_WEEKLY_REPORT_TEST_TO=

# Legacy weekday overdue cron — keep off
OVERDUE_EMAIL_ENABLED=false
OVERDUE_EMAIL_TEST_TO=

# Ops: Siteline billing without Clearstory match
SITELINE_CLEARSTORY_GAP_ALERT_ENABLED=true
SITELINE_CLEARSTORY_GAP_ALERT_TO=joannabelle.salalila@Goelservices.com
# SITELINE_CLEARSTORY_GAP_ALERT_CC=

# Optional: link in gap-alert email
# APP_DASHBOARD_URL=https://your-frontend/billings
