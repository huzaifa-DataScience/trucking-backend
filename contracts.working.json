    {
      "name": "paginatedContracts",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{bearer_token}}",
            "type": "text"
          }
        ],
        "body": {
          "mode": "graphql",
          "graphql": {
            "query": "query paginatedContracts($input: GetPaginatedContractsInput!) {\n    paginatedContracts(input: $input) {\n      cursor\n      hasNext\n      contracts {\n        id\n        internalProjectNumber\n        billingType\n        percentComplete\n        project {\n            projectNumber\n        }\n        payApps (months:[\"2024-09\"]){        \n           id\n            status\n            billingStart\n            billingEnd\n            timeZone\n            status\n            submittedAt\n        }        \n      }\n    }\n}",
            "variables": "{\n    \"input\": {\n        \"month\": \"2024-09\",\n        \"payAppStatus\": \"SUBMITTED_SYNCED_PAID\",\n        \"contractStatus\": \"ACTIVE\",\n        \"limit\": 50\n    }\n}"
          }
        },
        "url": {
          "raw": "{{hostname}}/graphql",
          "host": [
            "{{hostname}}"
          ],
          "path": [
            "graphql"
          ]
        }
      },
      "response": []
    },
