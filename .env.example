PORT=3000
NODE_ENV=development

# Signup: set to false to let new users log in immediately (no admin approval).
# Set to true (default) to require admin approval before new users can log in.
REQUIRE_SIGNUP_APPROVAL=true

# SQL Server (Construction Logistics DB)
DB_HOST=localhost
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD=
DB_DATABASE=TruckingReporting
DB_ENCRYPT=true
DB_TRUST_CERT=true

# Siteline API (get base URL and token from Siteline)
SITELINE_API_URL=https://api.siteline.com
SITELINE_API_TOKEN=
# Optional: if Siteline expects token in a custom header, set it (e.g. Api-Token, X-API-Key). Leave empty for "Authorization: Bearer <token>".
# SITELINE_AUTH_HEADER=
