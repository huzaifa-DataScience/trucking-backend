PORT=3005

NODE_ENV=development

# SQL Server
DB_HOST=CHANGE_ME
DB_PORT=1433
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME
DB_DATABASE=GoFormzDB
DB_ENCRYPT=false
DB_TRUST_CERT=true


# Siteline — token from Siteline dashboard. Nest merges env: shell/Docker vars override .env (see GET /siteline/status → dotEnvTokenMatchesLoaded).
# Use the same host as Postman (often production external API):
SITELINE_API_URL=https://api-external.siteline.com
# Legacy default token (GOEL DC / EntityID 2) if per-entity vars are unset
# SITELINE_API_TOKEN=CHANGE_ME
# Multi-company tokens (Ref_OurEntities.EntityID 1=GOEL, 2=GOEL DC, 3=DCB)
# SITELINE_API_TOKEN_ENTITY_1=CHANGE_ME
# SITELINE_API_TOKEN_ENTITY_2=CHANGE_ME
# SITELINE_API_TOKEN_ENTITY_3=CHANGE_ME
# Aging: per_entity (one snapshot per entity) or merged_null (one call, filter UI by entityId)
# SITELINE_AGING_COMPANY_ID_MODE=per_entity
# SITELINE_AGING_PRIMARY_ENTITY_ID=2
# Rate limiting / DB contention (optional)
# SITELINE_API_MAX_RETRIES=5
# SITELINE_API_RETRY_BACKOFF_MS=1500
# SITELINE_ENTITY_API_DELAY_MS=2000
# SITELINE_DISCOVERY_PAGE_DELAY_MS=300
# SITELINE_GET_CONTRACT_DELAY_MS=300
# SITELINE_DB_PERSIST_RETRIES=3

# Required for aging sync + GET /siteline/aging-report (agingDashboard is NOT on api-external).
# Firebase login for the Siteline web app (same as browser session on app.siteline.com).
SITELINE_API_URL_SECONDARY=https://api.siteline.com
# SITELINE_API_TOKEN_SECONDARY=
# SITELINE_REFRESH_TOKEN_SECONDARY=
# SITELINE_IDENTITY_API_KEY_SECONDARY=
# SITELINE_AUTH_EMAIL_SECONDARY=
# SITELINE_AUTH_PASSWORD_SECONDARY=

# Master kill-switch for ALL scheduled jobs (Siteline, Clearstory, Trimble, emails).
# Set to false during local development so no cron runs on startup. Default: true.
# CRONS_ENABLED=false

# Set false if your Siteline GraphQL does not expose `agingDashboard` (stops 400 spam in logs).
SITELINE_AGING_SNAPSHOT_ENABLED=true
# Data sync crons (6-field: sec min hour day month weekday). Default: every 6 hours.
# SITELINE_CONTRACT_SYNC_CRON=0 0 */6 * * *
# SITELINE_AGING_SNAPSHOT_CRON=0 15 */6 * * *

# Optional: pay-app page size for Siteline contract sync (1–200, default 100).
# SITELINE_PAY_APPS_SYNC_PAGE_SIZE=100
# Optional: delay in ms between each getContract during sync (429 backoff).
# SITELINE_GET_CONTRACT_DELAY_MS=0

# Set false to stop syncing Siteline_Contracts / Siteline_PayApps (reduces Siteline API load).
SITELINE_CONTRACT_SYNC_ENABLED=true

# Also page `paginatedContracts` with contractStatus ACTIVE (union contract ids with pay-apps discovery).
# SITELINE_CONTRACTS_PAGINATED_SYNC_ENABLED=false
# Page size for paginatedContracts (1–500, default 500).
# SITELINE_CONTRACTS_PAGINATED_SYNC_PAGE_SIZE=500
# Optional: pass through GetPaginatedContractsInput.payAppStatus when Siteline requires it.
# SITELINE_CONTRACTS_PAGINATED_PAY_APP_STATUS=

# Outbound email — Resend (preferred when RESEND_API_KEY is set) or Gmail SMTP fallback.
#
# --- Resend (https://resend.com) ---
# RESEND_API_KEY=re_xxxxxxxx
# From must use a domain verified in Resend, e.g.:
# RESEND_FROM=Goel Reports <reports@yourdomain.com>
# If RESEND_FROM is unset, OVERDUE_EMAIL_FROM is used.
#
# --- SMTP fallback (Gmail app password, etc.) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# OVERDUE_EMAIL_FROM=
#
# auto = use Resend when RESEND_API_KEY is set, else SMTP
# EMAIL_PROVIDER=auto
# OVERDUE_EMAIL_FROM=
# PM Monday report — only scheduled PM email (AR aging + Clearstory + T&M). Mon 6:00 AM US Eastern.
PM_WEEKLY_REPORT_ENABLED=true
PM_WEEKLY_REPORT_CRON=0 0 6 * * 1
SITELINE_PM_EMAIL_TIMEZONE=America/New_York
PM_WEEKLY_REPORT_DAYS=50
PM_WEEKLY_REPORT_TEST_TO=
# Legacy overdue-only job (no cron). Manual: npm run run-overdue-email
# OVERDUE_EMAIL_ENABLED=false
# OVERDUE_EMAIL_DAYS=50
# OVERDUE_EMAIL_TEST_TO=

# Siteline has billing/AR but no Clearstory project to compare — email ops (default JoAnnabelle).
# SITELINE_CLEARSTORY_GAP_ALERT_ENABLED=true
# SITELINE_CLEARSTORY_GAP_ALERT_TO=joannabelle.salalila@Goelservices.com
# SITELINE_CLEARSTORY_GAP_ALERT_CC=
# Optional link in template body: APP_DASHBOARD_URL=https://your-frontend/billings

# Clearstory vs Siteline comparison uses ACTIVE Siteline contracts and non-archived Clearstory projects only.

# PJ weekly: Tuesday 6 AM US Eastern — one email to PJ with a PDF per PM (same report PMs get Monday).
# Uses PM_WEEKLY_REPORT_DAYS for overdue AR column threshold.
# PJ_COR_WEEKLY_REPORT_ENABLED=false
# PJ_COR_WEEKLY_REPORT_TO=
# PJ_COR_WEEKLY_REPORT_TEST_TO=
# PJ_COR_WEEKLY_REPORT_CRON=0 0 6 * * 2

# Cron: print full Siteline JSON to stdout (see terminal running Nest). Optional max string length.
SITELINE_CRON_LOG_MAX_CHARS=500000
# Set true to log full getContract() JSON per contract (very verbose).
# SITELINE_CRON_LOG_CONTRACT_DETAIL=true

# Optional local Swagger file exposed at GET /swagger-test
# SWAGGER_TEST_FILE=/absolute/path/to/swagger.json

# Clearstory Web API (Basic Auth: Key ID + Secret Key)
CLEARSTORY_API_URL=https://web-api.clearstory.build
# CLEARSTORY_KEY_ID=
# CLEARSTORY_SECRET_KEY=
# Set false to stop Clearstory sync cron.
CLEARSTORY_SYNC_ENABLED=true
# Optional: set false to skip per-customer GET /customers/:id (much faster; list JSON only).
# CLEARSTORY_CUSTOMER_DETAIL=false
# Nest/cron 6-field expression (sec min hour day month weekday). Default: every 6 hours.
# CLEARSTORY_SYNC_CRON=0 0 */6 * * *
# Limit sync to specific Clearstory offices (divisions under the API-key company).
# Default: enabled — only offices whose name starts with "Goel Services, Inc." (excludes DCB, Goel DC, etc.).
# CLEARSTORY_OFFICE_SCOPE_ENABLED=true
# Comma-separated office IDs (overrides name prefixes when set). Example insulation only: 1190
# CLEARSTORY_OFFICE_IDS=1190,3426,3432
# CLEARSTORY_OFFICE_NAME_PREFIXES=Goel Services, Inc.
# After each sync, delete mirror rows for projects outside the allowed offices.
# CLEARSTORY_OFFICE_SCOPE_PRUNE=true