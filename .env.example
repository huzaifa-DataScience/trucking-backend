PORT=3005

NODE_ENV=development

# SQL Server (GoFormz DB) — local run pointing at prod DB
DB_HOST=ts01.8a.com
DB_PORT=1433
DB_USERNAME=sa
DB_PASSWORD="Goformz!@#"
DB_DATABASE=GoFormzDB
DB_ENCRYPT=false
DB_TRUST_CERT=true


# Siteline (use API token from Siteline dashboard/support)
SITELINE_API_URL=https://api.siteline.com
SITELINE_API_TOKEN=siteline_3b53a6c51fa7a966e2cff0cf38c17a87

# Set false if your Siteline GraphQL does not expose `agingDashboard` (stops 400 spam in logs).
SITELINE_AGING_SNAPSHOT_ENABLED=true

# Set false to stop syncing Siteline_Contracts / Siteline_PayApps (reduces Siteline API load).
SITELINE_CONTRACT_SYNC_ENABLED=true

# Cron: print full Siteline JSON to stdout (see terminal running Nest). Optional max string length.
SITELINE_CRON_LOG_MAX_CHARS=500000
# Set true to log full getContract() JSON per contract (very verbose).
# SITELINE_CRON_LOG_CONTRACT_DETAIL=true

# Optional local Swagger file exposed at GET /swagger-test
# SWAGGER_TEST_FILE=/absolute/path/to/swagger.json